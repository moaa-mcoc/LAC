}
.bill-row.priority .bill-num { color: #7a5c00; }
.bill-body { flex: 1; min-width: 0; }
.bill-title { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 3px; }
.bill-desc { font-size: 13px; color: var(--gray-500); line-height: 1.55; }
.bill-link { font-size: 12px; font-weight: 600; color: var(--navy); text-decoration: none; display: inline-flex; align-items: center; gap: 3px; margin-top: 5px; }
