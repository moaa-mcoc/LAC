.focus-card p { font-size: 14px; color: var(--navy-mid); line-height: 1.7; margin-bottom: 1rem; }
.resource-row { display: flex; gap: 10px; flex-wrap: wrap; }
.resource-link {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 13px; font-weight: 600; color: var(--navy);
  text-decoration: none; border: 1.5px solid var(--navy);
  padding: 6px 14px; border-radius: var(--radius);
  transition: background 0.15s, color 0.15s; background: #fff;
